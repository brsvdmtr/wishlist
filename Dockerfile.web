# Production Dockerfile for apps/web (Next.js)
FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.15.0 --activate
WORKDIR /app

# Dependencies
FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/db/package.json ./packages/db/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile

# Builder
FROM base AS builder
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json /app/pnpm-lock.yaml /app/pnpm-workspace.yaml ./
COPY --from=deps /app/apps/web/package.json ./apps/web/
COPY --from=deps /app/packages/db/package.json ./packages/db/
COPY --from=deps /app/packages/shared/package.json ./packages/shared/
COPY . .
RUN cd packages/db && pnpm install && cd ../..
RUN pnpm db:generate
RUN pnpm --filter @wishlist/shared build

# Next.js inlines NEXT_PUBLIC_* into the CLIENT bundle at build time. Server
# components keep reading runtime env (compose `environment:`), but anything
# touched by `'use client'` code (e.g. apps/web/app/miniapp/sentry.ts which
# initSentry() calls from MiniApp.tsx) needs these visible to `next build`.
# Compose wires the values via build args; see docker-compose.prod.yml → web.
ARG NEXT_PUBLIC_GLITCHTIP_DSN
ARG NEXT_PUBLIC_APP_RELEASE
ARG NEXT_PUBLIC_IMAGE_PROXY
ENV NEXT_PUBLIC_GLITCHTIP_DSN=$NEXT_PUBLIC_GLITCHTIP_DSN
ENV NEXT_PUBLIC_APP_RELEASE=$NEXT_PUBLIC_APP_RELEASE
ENV NEXT_PUBLIC_IMAGE_PROXY=$NEXT_PUBLIC_IMAGE_PROXY

RUN pnpm build:web

# Runner
FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

# Stash baked chunks for the entrypoint to merge into a mounted volume
# (or back into the now-empty chunks/ dir when no volume is mounted).
# See ops/web-entrypoint.sh and docs/BUGFIX_LESSONS.md (2026-05-27 —
# stale-HTML 404 syndrome).
RUN mv apps/web/.next/static/chunks apps/web/.next/static/chunks-baked && \
    mkdir -p apps/web/.next/static/chunks && \
    chown -R nextjs:nodejs apps/web/.next/static/chunks apps/web/.next/static/chunks-baked

COPY --chmod=0755 ops/web-entrypoint.sh /usr/local/bin/web-entrypoint.sh

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["/usr/local/bin/web-entrypoint.sh"]
CMD ["node", "apps/web/server.js"]
