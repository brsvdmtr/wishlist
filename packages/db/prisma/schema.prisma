generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ItemStatus {
  AVAILABLE
  RESERVED
  PURCHASED
  COMPLETED
  DELETED
}

enum ReservationType {
  RESERVED
  UNRESERVED
  PURCHASED
}

enum CommentType {
  USER
  SYSTEM
}

enum WishlistType {
  REGULAR
  SYSTEM_DRAFTS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum HintStatus {
  SENT
  DELIVERED
  CANCELLED
  EXPIRED
}

enum Currency {
  RUB
  USD
}

enum ProfileVisibility {
  ALL
  LINK_ONLY
  SUBSCRIBERS
  NOBODY
}

enum SubscribePolicy {
  ALL
  LINK_ONLY
  APPROVED
  NOBODY
}

enum WishlistVisibility {
  LINK_ONLY       // accessible via link, not shown in public profile (default)
  PUBLIC_PROFILE  // shown on owner's public profile (PRO)
  PRIVATE         // new users cannot access; existing subscribers retain access (PRO)
}

enum AllowSubscriptions {
  ALL    // anyone with wishlist access can subscribe
  NOBODY // no new subscriptions allowed
}

enum CommentPolicy {
  ALL         // anyone with wishlist access can comment
  SUBSCRIBERS // only subscribers can comment
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  telegramId     String?  @unique
  telegramChatId String?
  firstName      String?
  godMode        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wishlists              Wishlist[]
  subscriptions          Subscription[]
  paymentEvents          PaymentEvent[]
  commentReadCursors     CommentReadCursor[]
  hints                  Hint[]
  profile                UserProfile?
  wishlistSubscriptions  WishlistSubscription[]
  supportTickets         SupportTicket[]
}

model Wishlist {
  id          String    @id @default(cuid())
  slug        String    @unique
  shareToken  String?   @unique
  ownerId     String
  title       String
  description String?
  deadline    DateTime?
  archivedAt         DateTime?
  position           Int                @default(0)
  visibility         WishlistVisibility @default(LINK_ONLY)
  allowSubscriptions AllowSubscriptions @default(ALL)
  commentPolicy      CommentPolicy      @default(ALL)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  type WishlistType @default(REGULAR)

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items Item[]
  tags  Tag[]
  wishlistSubscriptions WishlistSubscription[]

  @@index([ownerId])
  @@index([ownerId, position])
}

model Item {
  id               String     @id @default(cuid())
  wishlistId       String
  title            String
  url              String
  description      String?    @db.VarChar(500)
  priceText        String?
  currency         Currency   @default(RUB)
  commentOwner     String?
  priority         Priority   @default(MEDIUM)
  deadline         DateTime?
  imageUrl         String?
  sourceUrl        String?
  sourceDomain     String?
  importMethod     String?
  status           ItemStatus @default(AVAILABLE)
  reservationEpoch Int        @default(0)
  position         Int        @default(0)
  reserverUserId   String?
  archivedAt       DateTime?
  purgeAfter       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  wishlist          Wishlist           @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  itemTags          ItemTag[]
  reservationEvents ReservationEvent[]
  comments          Comment[]
  commentReadCursors CommentReadCursor[]
  hints              Hint[]

  @@index([wishlistId])
  @@index([purgeAfter])
  @@index([wishlistId, priority, position])
}

model Tag {
  id         String   @id @default(cuid())
  wishlistId String
  name       String
  createdAt  DateTime @default(now())

  wishlist Wishlist  @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  itemTags ItemTag[]

  @@index([wishlistId])
}

model ItemTag {
  itemId String
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model ReservationEvent {
  id        String          @id @default(cuid())
  itemId    String
  type      ReservationType
  actorHash String
  comment   String?
  createdAt DateTime        @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Comment {
  id                String      @id @default(cuid())
  itemId            String
  type              CommentType @default(USER)
  authorActorHash   String?
  authorDisplayName String?
  text              String      @db.VarChar(300)
  reservationEpoch  Int         @default(0)
  scheduledDeleteAt DateTime?
  createdAt         DateTime    @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
  @@index([scheduledDeleteAt])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planCode           String             @default("PRO")
  status             SubscriptionStatus @default(ACTIVE)
  starsPrice         Int
  telegramChargeId   String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  source             String?            @default("telegram_stars")
  billingPeriod      String?            @default("monthly")
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@unique([userId, planCode])
  @@index([userId])
  @@index([currentPeriodEnd])
}

model PaymentEvent {
  id                      String   @id @default(cuid())
  subscriptionId          String?
  userId                  String
  telegramPaymentChargeId String   @unique
  providerPaymentChargeId String?
  invoicePayload          String
  totalAmount             Int
  currency                String   @default("XTR")
  eventType               String
  rawPayload              String?  @db.Text
  createdAt               DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
}

model CommentReadCursor {
  userId     String
  itemId     String
  lastReadAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([userId])
}

model Hint {
  id           String     @id @default(cuid())
  itemId       String
  senderUserId String
  status       HintStatus @default(SENT)
  createdAt    DateTime   @default(now())
  expiresAt    DateTime

  sentCount    Int?
  pendingCount Int?
  deliveredAt  DateTime?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([senderUserId, createdAt])
  @@index([expiresAt])
}

model UserProfile {
  id              String  @id @default(cuid())
  userId          String  @unique

  // Identity
  displayName     String?
  username        String?  @unique
  bio             String?  @db.VarChar(300)
  avatarUrl       String?
  birthday        DateTime?
  hideYear        Boolean  @default(false)

  // Settings — Currency
  defaultCurrency Currency @default(RUB)

  // Settings — Notifications
  notifyComments       Boolean @default(true)
  notifyReservations   Boolean @default(true)
  notifySubscriptions  Boolean @default(true)
  notifyMarketing      Boolean @default(false)

  // Settings — Privacy
  profileVisibility   ProfileVisibility @default(ALL)
  subscribePolicy     SubscribePolicy   @default(ALL)
  commentsEnabled     Boolean @default(true)
  hintsEnabled        Boolean @default(true)

  // Settings — App Behavior
  newWishlistPosition String  @default("bottom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WishlistSubscription {
  id             String    @id @default(cuid())
  wishlistId     String
  subscriberId   String
  createdAt      DateTime  @default(now())
  lastNotifiedAt DateTime?

  wishlist  Wishlist             @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  subscriber User               @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  unreads   SubscriptionUnread[]

  @@unique([wishlistId, subscriberId])
  @@index([subscriberId])
  @@index([wishlistId])
}

model SubscriptionUnread {
  id        String @id @default(cuid())
  subId     String
  entityId  String
  fieldName String

  subscription WishlistSubscription @relation(fields: [subId], references: [id], onDelete: Cascade)

  @@unique([subId, entityId, fieldName])
  @@index([subId])
}

model ServiceHeartbeat {
  serviceName String   @id
  updatedAt   DateTime @updatedAt
  metadata    String?
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

enum SupportTicketStatus {
  OPEN
  WAITING_SUPPORT
  WAITING_USER
  CLOSED
}

enum SupportMessageAuthorRole {
  USER
  SUPPORT
  SYSTEM
}

enum SupportMessageKind {
  TEXT
  PHOTO
  VIDEO
  DOCUMENT
  OTHER
}

model SupportTicket {
  id            String              @id @default(cuid())
  ticketCode    String              @unique
  userId        String
  status        SupportTicketStatus @default(OPEN)
  openedVia     String?
  supportChatId String?
  closedAt      DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId, status])
  @@index([status, updatedAt])
}

model SupportMessage {
  id                    String                   @id @default(cuid())
  ticketId              String
  authorRole            SupportMessageAuthorRole
  kind                  SupportMessageKind       @default(TEXT)
  text                  String?
  caption               String?
  telegramUserChatId    String?
  telegramUserMsgId     Int?
  telegramSupportChatId String?
  telegramSupportMsgId  Int?
  telegramFileId        String?
  createdAt             DateTime                 @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([telegramSupportMsgId])
  @@index([telegramUserMsgId])
}

// Tracks outstanding ForceReply support prompts so replies can be routed
// even after a bot restart. Cleaned up once consumed or expired.
model SupportSession {
  id              String   @id @default(cuid())
  telegramChatId  String
  promptMessageId Int
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([telegramChatId, promptMessageId])
  @@index([expiresAt])
}
