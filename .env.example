# =============================================================================
# WishBoard — Full Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in all values marked [REQUIRED]
# On production server: /opt/wishlist/.env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------

# Connection string for Prisma ORM. Used by: api, prisma CLI
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# In Docker: host = "postgres" (service name). Locally: "localhost"
DATABASE_URL=postgresql://wishlist:CHANGE_ME_DB_PASSWORD@postgres:5432/wishlist?schema=public

# PostgreSQL container credentials (used by postgres Docker image on first run)
POSTGRES_USER=wishlist
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD          # [REQUIRED] Must match DATABASE_URL
POSTGRES_DB=wishlist

# -----------------------------------------------------------------------------
# API Server (apps/api)
# -----------------------------------------------------------------------------

# Express server port (default: 3001)
PORT=3001

# Allowed CORS origin. Must match the public URL of the web app.
# [REQUIRED] Example: https://wishlistik.ru
WEB_ORIGIN=https://wishlistik.ru

# Secret key for admin API endpoints. Shared between api and web services.
# [REQUIRED] Generate: openssl rand -hex 32
ADMIN_KEY=CHANGE_ME_ADMIN_KEY

# Telegram Bot Token from @BotFather
# [REQUIRED] Format: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
BOT_TOKEN=CHANGE_ME_BOT_TOKEN

# Email for the system user record (created on first launch)
SYSTEM_USER_EMAIL=owner@local

# Directory for uploaded images (photos).
# In Docker: /data/uploads (mapped to persistent volume)
# Locally: ./uploads (relative to api working directory)
UPLOAD_DIR=/data/uploads

# NOT USED in current code. Defined in docker-compose but unused.
AUTH_SECRET=
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Web / Next.js (apps/web)
# -----------------------------------------------------------------------------

# Public API URL (visible in browser, used by client-side fetch).
# Must include /api prefix as nginx strips it via proxy_pass.
# [REQUIRED] Example: https://wishlistik.ru/api
NEXT_PUBLIC_API_BASE_URL=https://wishlistik.ru/api

# Public site URL (used for meta tags, Open Graph, canonical links).
# [REQUIRED] Example: https://wishlistik.ru
NEXT_PUBLIC_SITE_URL=https://wishlistik.ru

# Telegram bot username (without @). Used for deep link generation.
# [REQUIRED] Example: WishHub_bot
NEXT_PUBLIC_BOT_USERNAME=WishHub_bot

# Mini App short name (from BotFather). May be empty.
NEXT_PUBLIC_MINIAPP_SHORT_NAME=

# Internal API URL for server-side rendering (SSR).
# In Docker: http://api:3001 (internal network, no nginx).
# Locally: http://localhost:3001
INTERNAL_API_BASE_URL=http://api:3001

# HTTP Basic Auth credentials for /admin panel.
# [REQUIRED] Choose strong password.
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=CHANGE_ME_ADMIN_PASSWORD

# Disable Next.js telemetry in production.
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Telegram Bot (apps/bot)
# -----------------------------------------------------------------------------

# BOT_TOKEN is shared with API (see above).

# Full URL to Mini App page (opened via bot menu button).
MINI_APP_URL=https://wishlistik.ru/miniapp

# Public site URL (used in bot messages for links).
SITE_URL=https://wishlistik.ru

# Internal API URL (bot -> api, inside Docker network).
API_BASE_URL=http://api:3001

# -----------------------------------------------------------------------------
# Summary of REQUIRED secrets (must be changed from defaults)
# -----------------------------------------------------------------------------
#
# POSTGRES_PASSWORD    — database password
# ADMIN_KEY            — admin API authentication
# BOT_TOKEN            — Telegram bot token from @BotFather
# ADMIN_BASIC_PASS     — /admin panel password
# WEB_ORIGIN           — public URL (must match DNS/SSL)
# NEXT_PUBLIC_API_BASE_URL — public API URL
# NEXT_PUBLIC_SITE_URL — public site URL
#
# =============================================================================
