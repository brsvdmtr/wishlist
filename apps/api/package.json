{
  "name": "@wishlist/api",
  "private": true,
  "version": "0.0.0",
  "main": "dist/index.js",
  "scripts": {
    "predev": "pnpm -C ../../packages/db build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm -C ../../packages/db build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "seed": "pnpm -C ../../packages/db build && tsx src/seed.ts",
    "test": "vitest run src/sort.test.ts"
  },
  "dependencies": {
    "@wishlist/db": "workspace:*",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "^8.2.1",
    "multer": "^2.1.0",
    "puppeteer-core": "^24.38.0",
    "sharp": "^0.34.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/multer": "^2.0.0",
    "@types/sharp": "^0.32.0",
    "tsx": "4.16.2",
    "typescript": "5.5.4",
    "vitest": "^2.1.0"
  }
}
