generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ItemStatus {
  AVAILABLE
  RESERVED
  PURCHASED
  COMPLETED
  DELETED
}

enum ReservationType {
  RESERVED
  UNRESERVED
  PURCHASED
}

enum CommentType {
  USER
  SYSTEM
}

enum WishlistType {
  REGULAR
  SYSTEM_DRAFTS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  telegramId     String?  @unique
  telegramChatId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wishlists     Wishlist[]
  subscriptions Subscription[]
  paymentEvents PaymentEvent[]
}

model Wishlist {
  id          String    @id @default(cuid())
  slug        String    @unique
  shareToken  String?   @unique
  ownerId     String
  title       String
  description String?
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  type WishlistType @default(REGULAR)

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items Item[]
  tags  Tag[]

  @@index([ownerId])
}

model Item {
  id               String     @id @default(cuid())
  wishlistId       String
  title            String
  url              String
  description      String?    @db.VarChar(500)
  priceText        String?
  commentOwner     String?
  priority         Priority   @default(MEDIUM)
  deadline         DateTime?
  imageUrl         String?
  sourceUrl        String?
  sourceDomain     String?
  importMethod     String?
  status           ItemStatus @default(AVAILABLE)
  reservationEpoch Int        @default(0)
  reserverUserId   String?
  archivedAt       DateTime?
  purgeAfter       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  wishlist          Wishlist           @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  itemTags          ItemTag[]
  reservationEvents ReservationEvent[]
  comments          Comment[]

  @@index([wishlistId])
  @@index([purgeAfter])
}

model Tag {
  id         String   @id @default(cuid())
  wishlistId String
  name       String
  createdAt  DateTime @default(now())

  wishlist Wishlist  @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  itemTags ItemTag[]

  @@index([wishlistId])
}

model ItemTag {
  itemId String
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model ReservationEvent {
  id        String          @id @default(cuid())
  itemId    String
  type      ReservationType
  actorHash String
  comment   String?
  createdAt DateTime        @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Comment {
  id                String      @id @default(cuid())
  itemId            String
  type              CommentType @default(USER)
  authorActorHash   String?
  authorDisplayName String?
  text              String      @db.VarChar(300)
  reservationEpoch  Int         @default(0)
  scheduledDeleteAt DateTime?
  createdAt         DateTime    @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
  @@index([scheduledDeleteAt])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planCode           String             @default("PRO")
  status             SubscriptionStatus @default(ACTIVE)
  starsPrice         Int
  telegramChargeId   String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  source             String?            @default("telegram_stars")
  billingPeriod      String?            @default("monthly")
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@unique([userId, planCode])
  @@index([userId])
  @@index([currentPeriodEnd])
}

model PaymentEvent {
  id                      String   @id @default(cuid())
  subscriptionId          String?
  userId                  String
  telegramPaymentChargeId String   @unique
  providerPaymentChargeId String?
  invoicePayload          String
  totalAmount             Int
  currency                String   @default("XTR")
  eventType               String
  rawPayload              String?  @db.Text
  createdAt               DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
}
