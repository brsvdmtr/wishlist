{
  "name": "wishlist",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "node scripts/setup-githooks.mjs",
    "hooks:install": "node scripts/setup-githooks.mjs",
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "lint": "npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w apps/web",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema packages/db/prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema packages/db/prisma/schema.prisma"
  }
}
