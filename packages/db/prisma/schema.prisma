generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ItemStatus {
  AVAILABLE
  RESERVED
  PURCHASED
  COMPLETED
  DELETED
  ARCHIVED
}

enum ReservationType {
  RESERVED
  UNRESERVED
  PURCHASED
}

enum CommentType {
  USER
  SYSTEM
}

enum WishlistType {
  REGULAR
  SYSTEM_DRAFTS
}

enum ItemOriginType {
  MANUAL
  IMPORTED
  DEMO
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum PromoRedemptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  ACCEPTED_FOR_PAID
  FAILED
}

enum DegradationPhase {
  NONE
  GRACE_PERIOD
  ARCHIVED
  PURGED
}

enum HintStatus {
  SENT
  DELIVERED
  CANCELLED
  EXPIRED
}

enum Currency {
  RUB
  USD
  EUR
  GBP
}

enum ProfileVisibility {
  ALL
  LINK_ONLY
  SUBSCRIBERS
  NOBODY
}

enum SubscribePolicy {
  ALL
  LINK_ONLY
  APPROVED
  NOBODY
}

enum WishlistVisibility {
  LINK_ONLY // accessible via link, not shown in public profile (default)
  PUBLIC_PROFILE // shown on owner's public profile (PRO)
  PRIVATE // new users cannot access; existing subscribers retain access (PRO)
}

enum AllowSubscriptions {
  ALL // anyone with wishlist access can subscribe
  NOBODY // no new subscriptions allowed
}

enum CommentPolicy {
  ALL // anyone with wishlist access can comment
  SUBSCRIBERS // only subscribers can comment
}

// Referral program — attribution lifecycle
// ATTRIBUTED: invitee clicked link, came into bot, got tied to inviter
// PENDING_ACTIVATION: attribution recorded, waiting for qualifying action (wishlist + item)
// QUALIFIED: invitee did qualifying action within window — ready to reward
// REWARDED: inviter received PRO days — terminal success
// REJECTED: auto-rejected (not new user / prior wishlist / cap reached / timeout)
// FRAUD_REVIEW: fraud score crossed threshold, waiting for admin
enum ReferralAttributionStatus {
  ATTRIBUTED
  PENDING_ACTIVATION
  QUALIFIED
  REWARDED
  REJECTED
  FRAUD_REVIEW
}

// Referral reject reasons — enum keeps matrix tight; new values need matrix update in S12
enum ReferralRejectReason {
  INVITEE_NOT_NEW_USER
  INVITEE_HAD_PRIOR_DIALOG
  INVITEE_HAD_PRIOR_WISHLIST
  INVITEE_HAD_PRIOR_ITEM
  INVITEE_ALREADY_ATTRIBUTED
  SELF_REFERRAL_DETECTED
  REWARD_CAP_REACHED
  QUALIFICATION_TIMEOUT
  PROGRAM_DISABLED
  SYSTEM_CONFLICT
  FRAUD_REJECTED
  INVITER_BANNED
  INVITER_DELETED
}

enum ReferralRewardStatus {
  GRANTED
  REVOKED
}

// Lifecycle of an Idempotency-Key record:
//   processing — handler is running (or crashed before completion); guarded by `lockedUntil`
//   completed  — handler finished; replay returns the stored response
//   failed     — handler returned 5xx; same key may retry once `lockedUntil` expires
enum IdempotencyStatus {
  processing
  completed
  failed
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  telegramId     String?  @unique
  telegramChatId String?
  firstName      String?
  // Additional Telegram identity fields. Captured opportunistically on
  // every authenticated request (Mini App initData) and on every bot
  // /start. Not used for auth decisions — purely for dashboards, support
  // lookup ("@username"), and richer god-mode segmentation. isPremium
  // tracks whether the user has Telegram Premium at last-seen time.
  lastName       String?
  username       String?
  isPremium      Boolean  @default(false)
  // DEPRECATED (2026-05-28): legacy god-mode persistence. No longer read on
  // any privilege-granting path — effective god access is env-derived from
  // GOD_MODE_TELEGRAM_IDS (see services/telegram-auth.ts isGodModeTelegramId).
  // Inert; a follow-up migration drops it. Do NOT reintroduce reads.
  godMode        Boolean  @default(false)
  // Operator's own on/off switch for god-mode, restored 2026-05-29 after the
  // 28.05 env-only change removed the toggle entirely (leaving god permanently
  // ON for allowlisted operators). Effective god = isGodModeTelegramId(tid)
  // AND godModeActive — so this can only ever SUPPRESS god for an eligible
  // operator, never GRANT it to anyone outside GOD_MODE_TELEGRAM_IDS. Default
  // true so allowlisted operators keep god ON until they choose to dogfood as
  // a normal user. Inert for non-allowlisted users (ANDed with a false env).
  godModeActive  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wishlists                      Wishlist[]
  subscriptions                  Subscription[]
  paymentEvents                  PaymentEvent[]
  commentReadCursors             CommentReadCursor[]
  hints                          Hint[]
  hintQuotaCharges               HintQuotaCharge[]
  profile                        UserProfile?
  wishlistSubscriptions          WishlistSubscription[]
  supportTickets                 SupportTicket[]
  addOns                         UserAddOn[]
  credits                        UserCredits?
  purchases                      Purchase[]
  welcomeSent                    Boolean                        @default(true)
  santaTestMode                  Boolean                        @default(false)
  ownedSantaCampaigns            SantaCampaign[]                @relation("OwnedSantaCampaigns")
  santaParticipations            SantaParticipant[]             @relation("SantaParticipations")
  santaNotifications             SantaNotification[]            @relation("SantaNotifications")
  santaExclusionGroupMemberships SantaExclusionGroupMember[]    @relation("ExclusionGroupMemberships")
  onboardingStates               UserOnboardingState[]
  promoRedemptions               PromoRedemption[]
  degradationState               DegradationState?
  lifecycleTouches               LifecycleTouch[]
  researchSurveyInvites          ResearchSurveyInvite[]
  researchSurveyResponses        ResearchSurveyResponse[]
  giftOccasions                  GiftOccasion[]                 @relation("GiftOccasionsOwner")
  giftOccasionIdeas              GiftOccasionIdea[]             @relation("GiftOccasionIdeasOwner")
  giftOccasionReminders          GiftOccasionReminder[]         @relation("GiftOccasionRemindersOwner")
  linkedGiftOccasions            GiftOccasion[]                 @relation("GiftOccasionsLinkedUser")
  calendarInbox                  CalendarInboxEntry[]           @relation("CalendarInboxOwner")
  maintenanceExposures           MaintenanceExposure[]
  groupGiftsOrganized            GroupGift[]                    @relation("GroupGiftOrganizer")
  groupGiftParticipations        GroupGiftParticipant[]         @relation("GroupGiftParticipations")
  groupGiftMessages              GroupGiftMessage[]             @relation("GroupGiftMessages")
  curatedSelections              CuratedSelection[]
  curatedSelectionSubscriptions  CuratedSelectionSubscription[]
  profileSubscriptions           ProfileSubscription[]          @relation("ProfileSubscriber")
  profileSubscribers             ProfileSubscription[]          @relation("ProfileTarget")
  secretReservations             SecretReservation[]
  foreignWishlistAccesses        ForeignWishlistAccess[]

  // Birthday reminders — social notifications for own birthday (separate from GiftOccasion)
  birthdayDeliveriesAsBirthdayUser BirthdayReminderDelivery[] @relation("BirthdayDeliveriesAsBirthdayUser")
  birthdayDeliveriesAsRecipient    BirthdayReminderDelivery[] @relation("BirthdayDeliveriesAsRecipient")
  birthdayMutesByUser              BirthdayReminderMute[]     @relation("BirthdayMutesByUser")
  birthdayMutesAsMutedUser         BirthdayReminderMute[]     @relation("BirthdayMutesAsMutedUser")

  // Referral program
  referralAttributionsAsInviter ReferralAttribution[] @relation("ReferralInviter")
  referralAttributionsAsInvitee ReferralAttribution[] @relation("ReferralInvitee")
  referralRewards               ReferralReward[]

  // v2.1 Appearance preferences (free: dark+violet only; PRO unlocks rest)
  // Validated server-side in PATCH /tg/settings/appearance.
  themePreference  String @default("dark") // 'dark' | 'black'
  accentPreference String @default("violet") // 'violet' | 'blue' | 'pink' | 'green'

  // Set once when the user dismisses or finishes the calendar 4-step
  // onboarding. Persisted on the User row so the same account doesn't see
  // onboarding again when switching devices (was localStorage-only before,
  // which made every fresh client re-run the flow).
  calendarOnboardingSeenAt DateTime?

  dailyActivity            UserDailyActivity[]
  experimentAssignments    ExperimentAssignment[]
}

model Wishlist {
  id                 String             @id @default(cuid())
  slug               String             @unique
  shareToken         String?            @unique
  shareOpenCount     Int                @default(0) // incremented on each GET /public/share/:token call
  ownerId            String
  title              String
  /// Optional user-chosen emoji shown next to the title in the hero card.
  /// When null, the UI falls back to a hash-derived auto-pick from title.
  emoji              String?
  description        String?
  deadline           DateTime?
  archivedAt         DateTime?
  position           Int                @default(0)
  visibility         WishlistVisibility @default(LINK_ONLY)
  allowSubscriptions AllowSubscriptions @default(ALL)
  commentPolicy      CommentPolicy      @default(ALL)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  type WishlistType @default(REGULAR)

  /// Marks the auto-created default REGULAR wishlist materialised for new
  /// users at bootstrap (E04 activation). Cleared by either
  /// POST /tg/onboarding/create-wishlist OR POST /tg/wishlists when the
  /// user names their first wishlist — both sites RENAME the row in place
  /// (preserving id, items, placements) rather than insert a duplicate.
  /// Backfill is not required; pre-existing rows stay false. See
  /// services/wishlists.ts:createGetOrCreateDefaultWishlist.
  ///
  /// A partial unique index `(ownerId) WHERE isDefault = true` enforces
  /// "at most one default per owner" at the DB level — Prisma DSL doesn't
  /// support partial indexes, so the constraint lives in the migration
  /// `20260525130000_unique_default_wishlist_per_owner/migration.sql`.
  /// Both bootstrap and onboarding-rename catch P2002 on that index and
  /// fall through to a re-fetch to handle the race.
  isDefault Boolean @default(false)

  // Don't Gift (per-wishlist override)
  dontGiftMode        String   @default("global") // "global" | "local" | "hidden"
  dontGiftPresets     String[] @default([])
  dontGiftCustomItems String[] @default([])
  dontGiftComment     String?

  // Smart Reservations
  smartReservationsEnabled Boolean @default(false)
  smartResTtlHours         Int     @default(72)
  smartResAllowExtend      Boolean @default(true)
  smartResMaxExtensions    Int     @default(2)

  owner                 User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items                 Item[]
  placements            WishlistItemPlacement[]
  tags                  Tag[]
  categories            WishlistCategory[]
  wishlistSubscriptions WishlistSubscription[]
  santaParticipants     SantaParticipant[]      @relation("SantaLinkedWishlists")
  curatedSelections     CuratedSelection[]
  linkedGiftOccasions   GiftOccasion[]          @relation("GiftOccasionsLinkedWishlist")
  foreignAccesses       ForeignWishlistAccess[]

  @@index([ownerId])
  @@index([ownerId, position])
}

model Item {
  id               String         @id @default(cuid())
  wishlistId       String
  title            String
  url              String
  description      String?        @db.VarChar(500)
  priceText        String?
  currency         Currency       @default(RUB)
  commentOwner     String?
  priority         Priority       @default(MEDIUM)
  deadline         DateTime?
  imageUrl         String?
  sourceUrl        String?
  sourceDomain     String?
  importMethod     String?
  isDemo           Boolean        @default(false)
  originType       ItemOriginType @default(MANUAL)
  originVariantKey String?
  becameRealAt     DateTime?
  status           ItemStatus     @default(AVAILABLE)
  reservationEpoch Int            @default(0)
  position         Int            @default(0)
  categoryId       String?
  reserverUserId   String?
  archivedAt       DateTime?
  purgeAfter       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  wishlist              Wishlist                @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  category              WishlistCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  placements            WishlistItemPlacement[]
  itemTags              ItemTag[]
  reservationEvents     ReservationEvent[]
  comments              Comment[]
  commentReadCursors    CommentReadCursor[]
  hints                 Hint[]
  santaItemReservations SantaItemReservation[]
  reservationMeta       ReservationMeta[]
  secretReservations    SecretReservation[]
  groupGift             GroupGift?

  @@index([wishlistId])
  @@index([purgeAfter])
  @@index([wishlistId, priority, position])
  @@index([categoryId])
}

model Tag {
  id         String   @id @default(cuid())
  wishlistId String
  name       String
  createdAt  DateTime @default(now())

  wishlist Wishlist  @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  itemTags ItemTag[]

  @@index([wishlistId])
}

model ItemTag {
  itemId String
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model ReservationEvent {
  id        String          @id @default(cuid())
  itemId    String
  type      ReservationType
  actorHash String
  comment   String?
  createdAt DateTime        @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Comment {
  id                String      @id @default(cuid())
  itemId            String
  type              CommentType @default(USER)
  authorActorHash   String?
  authorDisplayName String?
  text              String      @db.VarChar(300)
  reservationEpoch  Int         @default(0)
  scheduledDeleteAt DateTime?
  parentCommentId   String?
  createdAt         DateTime    @default(now())

  item    Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([itemId, createdAt])
  @@index([parentCommentId])
  @@index([scheduledDeleteAt])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planCode           String             @default("PRO")
  status             SubscriptionStatus @default(ACTIVE)
  starsPrice         Int
  telegramChargeId   String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  source             String?            @default("telegram_stars")
  billingPeriod      String?            @default("monthly")
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@unique([userId, planCode])
  @@index([userId])
  @@index([currentPeriodEnd])
}

model PaymentEvent {
  id                      String   @id @default(cuid())
  subscriptionId          String?
  userId                  String
  telegramPaymentChargeId String   @unique
  providerPaymentChargeId String?
  invoicePayload          String
  totalAmount             Int
  currency                String   @default("XTR")
  eventType               String
  rawPayload              String?  @db.Text
  createdAt               DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
}

model CommentReadCursor {
  userId     String
  itemId     String
  lastReadAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([userId])
}

model Hint {
  id           String     @id @default(cuid())
  itemId       String
  senderUserId String
  status       HintStatus @default(SENT)
  createdAt    DateTime   @default(now())
  expiresAt    DateTime

  sentCount    Int?
  pendingCount Int?
  deliveredAt  DateTime?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([senderUserId, createdAt])
  @@index([expiresAt])
}

// Audit ledger for hint-quota consumption — one immutable row per delivered
// hint. Written by consumeHintCharge() (services/hint-credits.ts) when the bot
// reports a hint DELIVERED via POST /internal/hints/credit.
//
//   • hintId is UNIQUE → the idempotency guard. Telegram can double-fire the
//     users_shared event; the unique constraint makes a second charge a no-op.
//   • hintId is a plain denormalized string, NOT a foreign key. A charge row
//     must OUTLIVE its Hint: Hints are cascade-deleted when their Item is
//     deleted, and if the ledger cascaded too a user could refund their
//     monthly quota simply by deleting the wish. The ledger is the source of
//     truth for "free hints used this month" (COUNT by userId + period).
//   • source — free_monthly | paid_pack | grace | pro. charged is true only
//     for free_monthly / paid_pack (a unit was actually spent).
//   • grace — the FREE quota was available when the hint wave was created but
//     exhausted by the time delivery completed; we deliver anyway (charged
//     false) rather than punish a user mid-scenario. reason records why.
//   • amount — units spent by this charge. Always 1 today (one delivered hint
//     = one unit); recorded explicitly so the ledger is self-describing and
//     leaves headroom for a future multi-unit charge.
model HintQuotaCharge {
  id        String   @id @default(cuid())
  userId    String
  hintId    String   @unique
  period    String
  source    String
  charged   Boolean
  amount    Int      @default(1)
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period])
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Identity
  displayName     String?
  username        String?   @unique
  bio             String?   @db.VarChar(300)
  avatarUrl       String?
  avatarThumbUrl  String?
  avatarUpdatedAt DateTime?
  avatarPublic    Boolean   @default(true)
  birthday        DateTime?
  hideYear        Boolean   @default(false)

  // Settings — Currency
  defaultCurrency Currency @default(RUB)

  // Settings — Notifications
  notifyComments      Boolean @default(true)
  notifyReservations  Boolean @default(true)
  notifySubscriptions Boolean @default(true)
  notifyMarketing     Boolean @default(true)
  notifyBirthdays     Boolean @default(true)

  // Birthday reminders — opt-in social notifications about user's own birthday.
  // birthdayFriendReminders defaults to false: existing users with `birthday` set MUST
  // explicitly opt in via the post-save sheet before any notifications fire.
  // birthdayOwnerReminders defaults to true (self-only): user gets reminders to update wishlist.
  // birthdayAudience: 'SUBSCRIBERS' (free) | 'EXTENDED' (Pro). Pro-only values are
  // rejected at API layer with 402 PRO_REQUIRED — never silent-saved as inactive.
  // birthdayAdvancedWindowsEnabled: Pro-only flag enabling 7d/1d friend windows and 14d/7d owner windows.
  // birthdayPrimaryWishlistId: Pro-only — overrides auto-pick of public wishlist for friend CTAs.
  // birthdayCustomMessage: Pro-only — appears in italics inside friend reminder bot message.
  // birthdayOptInPromptSeenAt: stamp when user saw post-save opt-in sheet (don't re-show).
  birthdayFriendReminders        Boolean   @default(false)
  birthdayOwnerReminders         Boolean   @default(true)
  birthdayAudience               String    @default("SUBSCRIBERS")
  birthdayAdvancedWindowsEnabled Boolean   @default(false)
  birthdayPrimaryWishlistId      String?
  birthdayCustomMessage          String?   @db.VarChar(200)
  birthdayOptInPromptSeenAt      DateTime?

  // Settings — Privacy
  profileVisibility ProfileVisibility @default(ALL)
  subscribePolicy   SubscribePolicy   @default(ALL)
  commentsEnabled   Boolean           @default(true)
  hintsEnabled      Boolean           @default(true)

  // Settings — Language
  // `language` is legacy — no longer used as effective locale source.
  language       String?
  // 'auto' = follow Telegram language_code; 'manual' = use manualLanguage
  languageMode   String  @default("auto")
  // Locale chosen by user when languageMode='manual'. Null in auto mode.
  manualLanguage String?

  // Settings — App Behavior
  newWishlistPosition String @default("bottom")
  cardDisplayMode     String @default("auto") // auto | showcase | compact

  // Growth prompts
  firstWishSharePromptShown     Boolean @default(false)
  readyWishlistSharePromptShown Boolean @default(false)

  // Derived market segmentation (computed from language on every request)
  normalizedLocale      String? // Canonical locale: ru | en | zh-CN | hi | es | ar
  marketBucket          String? // Market bucket: ru | ar | en | hi | zh-CN | es | other_known | unknown
  supportedImportRegion Boolean? // true if user is in a market where URL import works reliably

  // First-touch acquisition attribution (source tagging for traffic analysis)
  firstAcquisitionSource   String?
  firstAcquisitionMedium   String?
  firstAcquisitionCampaign String?
  firstAcquisitionRef      String?
  firstAcquisitionAt       DateTime?

  // Referral program — owner-side fields
  // referralCode: stable 5-6 char code for this user's ?start=ref_<code> link (lazy-generated)
  // referredByUserId: who invited this user (null for organic). Locked first-touch.
  // referredAt: when attribution was recorded.
  // firstBotStartAt / firstWishlistAt / firstItemAt: timestamps for qualifying-action detection
  //   and for invitee_had_prior_* gating. Written once, never updated.
  referralCode          String?   @unique
  referralCodeCreatedAt DateTime?
  referredByUserId      String?
  referredAt            DateTime?
  firstBotStartAt       DateTime?
  firstWishlistAt       DateTime?
  firstItemAt           DateTime?

  // Don't Gift
  dontGiftPresets     String[] @default([])
  dontGiftCustomItems String[] @default([])
  dontGiftComment     String?
  dontGiftVisible     Boolean  @default(true)

  // PRO Showcase (premium profile & wishlist showcase)
  showcaseEnabled      Boolean   @default(false)
  showcaseCoverUrl     String?
  showcaseBio          String?   @db.VarChar(180)
  showcasePinnedIds    String[]  @default([])
  showcasePreferences  String?   @db.VarChar(300)
  showcaseSizeClothing String?
  showcaseSizeShoes    String?
  showcaseSizeRing     String?
  showcaseSizeOther    String?
  // Body measurements (cm). Free-text strings so users can add units/comments.
  showcaseChest        String?
  showcaseWaist        String?
  showcaseHips         String?
  showcaseBrands       String[]  @default([])
  showcaseUpdatedAt    DateTime?

  // Support
  supportId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WishlistSubscription {
  id             String    @id @default(cuid())
  wishlistId     String
  subscriberId   String
  createdAt      DateTime  @default(now())
  lastNotifiedAt DateTime?

  wishlist   Wishlist             @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  subscriber User                 @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  unreads    SubscriptionUnread[]

  @@unique([wishlistId, subscriberId])
  @@index([subscriberId])
  @@index([wishlistId])
}

model SubscriptionUnread {
  id        String @id @default(cuid())
  subId     String
  entityId  String
  fieldName String

  subscription WishlistSubscription @relation(fields: [subId], references: [id], onDelete: Cascade)

  @@unique([subId, entityId, fieldName])
  @@index([subId])
}

// Follow another user's public profile (showcase). Separate from WishlistSubscription —
// this is a "follow the person" relation, independent of any specific wishlist.
model ProfileSubscription {
  id           String   @id @default(cuid())
  subscriberId String
  targetUserId String
  createdAt    DateTime @default(now())

  subscriber User @relation("ProfileSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  target     User @relation("ProfileTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, targetUserId])
  @@index([subscriberId])
  @@index([targetUserId])
}

model ServiceHeartbeat {
  serviceName String   @id
  updatedAt   DateTime @updatedAt
  metadata    String?
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

enum SupportTicketStatus {
  OPEN
  WAITING_SUPPORT
  WAITING_USER
  CLOSED
}

enum SupportMessageAuthorRole {
  USER
  SUPPORT
  SYSTEM
}

enum SupportMessageKind {
  TEXT
  PHOTO
  VIDEO
  DOCUMENT
  OTHER
}

model SupportTicket {
  id            String              @id @default(cuid())
  ticketCode    String              @unique
  userId        String
  status        SupportTicketStatus @default(OPEN)
  openedVia     String?
  supportChatId String?
  closedAt      DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId, status])
  @@index([status, updatedAt])
}

model SupportMessage {
  id                    String                   @id @default(cuid())
  ticketId              String
  authorRole            SupportMessageAuthorRole
  kind                  SupportMessageKind       @default(TEXT)
  text                  String?
  caption               String?
  telegramUserChatId    String?
  telegramUserMsgId     Int?
  telegramSupportChatId String?
  telegramSupportMsgId  Int?
  telegramFileId        String?
  createdAt             DateTime                 @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([telegramSupportMsgId])
  @@index([telegramUserMsgId])
}

// Tracks outstanding ForceReply support prompts so replies can be routed
// even after a bot restart. Cleaned up once consumed or expired.
model SupportSession {
  id              String   @id @default(cuid())
  telegramChatId  String
  promptMessageId Int
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([telegramChatId, promptMessageId])
  @@index([expiresAt])
}

// ─── One-time purchase add-ons & credits ─────────────────────────────────────

// Permanent add-ons: extra wishlist slots, subscription slots, per-wishlist item
// upgrades, seasonal decorations. Each row = one unit purchased.
// addonType values: 'wishlist_slot' | 'subscription_slot' |
//                  'item_slot_5' | 'item_slot_15' | 'seasonal_decoration'
// targetId: wishlistId for wishlist-scoped add-ons, null for account-level.
model UserAddOn {
  id        String   @id @default(cuid())
  userId    String
  addonType String
  quantity  Int      @default(1)
  targetId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, addonType])
}

// Consumable balances + monthly free-tier quota.
//   • hintCredits / importCredits — paid one-time packs (hints_pack_*,
//     import_pack_*). Never expire.
//   • freeImportsUsed / freeImportsPeriod — FREE-tier URL-import allowance:
//     N imports per UTC calendar month. freeImportsPeriod is the "YYYY-MM"
//     bucket; consume lazily zeroes the counter when the month rolls over
//     (no scheduler). Consumption order is free-first, then paid.
//     See apps/api/src/services/import-credits.ts.
// PRO users bypass every credit/quota check entirely (server-side).
model UserCredits {
  id                String   @id @default(cuid())
  userId            String   @unique
  hintCredits       Int      @default(0)
  importCredits     Int      @default(0)
  freeImportsUsed   Int      @default(0)
  freeImportsPeriod String?
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Immutable purchase log for one-time SKU payments (not subscriptions).
// Idempotency key: telegramChargeId.
model Purchase {
  id               String   @id @default(cuid())
  userId           String
  skuCode          String
  quantity         Int      @default(1)
  targetId         String?
  starsPrice       Int
  telegramChargeId String   @unique
  invoicePayload   String
  status           String   @default("completed")
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([telegramChargeId])
  @@index([userId, skuCode])
}

// ─────────────────────────────────────────────────────────────
// Promo campaigns & redemptions
// ─────────────────────────────────────────────────────────────

model PromoCampaign {
  id             String   @id @default(cuid())
  code           String   @unique // canonical: WISHPRO
  rewardType     String   @default("promo_pro") // promo_pro | future types
  durationDays   Int      @default(30)
  isActive       Boolean  @default(true)
  maxRedemptions Int? // null = unlimited
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id              String                @id @default(cuid())
  userId          String
  campaignId      String
  status          PromoRedemptionStatus @default(PENDING)
  attemptedAt     DateTime              @default(now())
  activatedAt     DateTime?
  expiresAt       DateTime?
  failureReason   String?
  source          String?               @default("miniapp") // miniapp | bot | winback
  offeredAt       DateTime? // when lifecycle system offered promo to this user
  offeredVia      String? // lifecycle touch ID or manual
  reminder3dSent  Boolean               @default(false)
  reminderExpSent Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign PromoCampaign @relation(fields: [campaignId], references: [id])

  @@unique([userId, campaignId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// Degradation state after PRO/promo-PRO expiration
model DegradationState {
  id                  String           @id @default(cuid())
  userId              String           @unique
  phase               DegradationPhase @default(NONE)
  graceEndsAt         DateTime? // 14 days after downgrade
  archivedAt          DateTime? // when items were archived
  purgeScheduledAt    DateTime? // 90 days after archive
  archivedWishlistIds String? // JSON array of archived wishlist IDs
  archivedItemIds     String? // JSON array of archived item IDs
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Lifecycle / Win-back messaging
// ─────────────────────────────────────────────────────────────

model LifecycleTouch {
  id                  String    @id @default(cuid())
  userId              String
  segment             String // S1, S2, S3, S4
  episodeKey          String // unique per churn episode (e.g. "S3_userId_2026-03")
  touchNumber         Int // 1, 2, 3
  scheduledFor        DateTime
  sentAt              DateTime?
  delivered           Boolean   @default(false)
  targetAction        String? // create_wishlist, add_item, return_visit, share
  offerCode           String? // WISHPRO or null — only on eligible touches
  messageKind         String // activation, winback, promo_offer
  deepLinkPayload     String? // startapp payload for CTA button
  stoppedAt           DateTime?
  stopReason          String? // returned, target_completed, unsubscribed, delivery_failed, bought_pro
  // Attribution tracking
  returnedAt          DateTime? // when user came back after this touch
  targetCompletedAt   DateTime? // when user completed segment target action
  targetCompletedType String? // e.g. created_wishlist, added_item, updated_wishlist
  promoRedeemedAt     DateTime? // when WISHPRO was activated after this touch
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeKey, touchNumber])
  @@index([userId, segment])
  @@index([scheduledFor, sentAt])
  @@index([userId, offerCode])
  @@index([sentAt])
}

// ─────────────────────────────────────────────────────────────
// Secret Santa feature
// ─────────────────────────────────────────────────────────────

enum SantaCampaignStatus {
  DRAFT
  OPEN
  LOCKED
  DRAW_IN_PROGRESS
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SantaCampaignType {
  CLASSIC
  MULTI_WAVE
}

enum SantaParticipantStatus {
  INVITED
  JOINED
  LEFT
  REMOVED
}

enum SantaGiftStatus {
  PENDING // giver hasn't decided yet (initial state)
  BUYING // legacy — treated as SELECTED_OUTSIDE in new flows; kept for backwards compat
  SELECTED_FROM_WISHLIST // giver chose an item from receiver's wishlist
  SELECTED_OUTSIDE // giver chose something not from the wishlist
  DECLINED_TO_SAY // giver confirms participation but won't disclose selection
  SENT // gift physically sent / handed over; receiver can now confirm
  RECEIVED // receiver confirmed — terminal; unlocks personal reveal
  MISSED_DEADLINE // auto-set by cron when drawAt passed and giver hasn't acted; recoverable
  ORPHANED // terminal: giver's exit request was approved while round was ACTIVE
}

enum SantaParticipantRole {
  PARTICIPANT // default role
  ADMIN // elevated role — can perform organizer actions alongside the owner
}

enum SantaExitRequestStatus {
  PENDING // submitted, awaiting organizer decision
  APPROVED // organizer approved; participant removed + assignment orphaned if applicable
  DENIED // organizer denied; participant stays JOINED
}

enum SantaDrawStatus {
  PENDING
  IN_PROGRESS
  DONE
  FAILED
}

enum SantaHintStatus {
  PENDING // giver requested, receiver hasn't responded yet
  FULFILLED // receiver selected wishlist items; giver can see them
  EXPIRED // TTL exceeded (48h) without receiver response
  CANCELLED // campaign cancelled or draw context invalidated
}

enum SantaNotificationType {
  JOINED
  LEFT
  DRAW_DONE
  GIFT_STATUS_CHANGED
  HINT_REQUEST
  HINT_RESPONDED
  CAMPAIGN_CANCELLED
  GIFT_RECEIVED // sent to giver when receiver marks their gift RECEIVED
  REVEAL_UNLOCKED // sent to receiver after they confirm RECEIVED (their reveal is ready)
  DEADLINE_WARNING // sent to giver ~3 days before drawAt if still PENDING
  DEADLINE_MISSED // sent to giver when their status is auto-updated to MISSED_DEADLINE
  CHAT_MESSAGE // new message in campaign chat (suppressed by mute)
  POLL_CREATED // new poll opened in campaign (suppressed by mute)
  EXIT_REQUEST_SUBMITTED // participant submitted an exit request (sent to organizers)
  EXIT_REQUEST_APPROVED // organizer approved participant's exit request (sent to participant)
  EXIT_REQUEST_DENIED // organizer denied participant's exit request (sent to participant)
}

enum SantaChatMessageType {
  USER // regular participant message
  SYSTEM // system-generated event message (no sender)
}

/// Singleton global master switch for Secret Santa.
/// Exactly one row exists (id = 'global'), auto-created at server startup.
/// Set santaEnabled=false to retire the feature entirely (overrides all season/calendar logic).
/// santaTestMode users (godMode) bypass this switch so product owners can always test.
model SantaGlobalConfig {
  id           String   @id @default("global")
  santaEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

/// Tracks seasonal broadcast notifications to prevent duplicate sends each year.
/// One row per (year, type). Insert races resolve to first-writer-wins via unique constraint.
model SantaSeasonalBroadcastLog {
  id        String   @id @default(cuid())
  /// Season start year (the November year — e.g. 2026 for the Nov 2026 → Feb 2027 season).
  year      Int
  /// 'PROMO' (Nov 1) or 'CLOSING_SOON' (Feb 1).
  type      String
  sentAt    DateTime @default(now())
  userCount Int      @default(0)

  @@unique([year, type])
}

// Optional per-year admin override. When a row exists for seasonYear it takes full priority
// over the recurring calendar rules. Allows changing dates or killing creates mid-season.
// canCreateCampaign = effectiveInSeason && campaignCreateEnabled (computed, never mutated automatically).
model SantaSeasonConfig {
  id                    String   @id @default(cuid())
  seasonYear            Int      @unique
  seasonStartAt         DateTime
  seasonEndAt           DateTime
  campaignCreateEnabled Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model SantaCampaign {
  id           String              @id @default(cuid())
  title        String
  description  String?
  type         SantaCampaignType   @default(CLASSIC)
  status       SantaCampaignStatus @default(DRAFT)
  ownerId      String
  // inviteToken is always non-null. Revocation = campaign CANCELLED status. No rotation in Batch 1.
  inviteToken  String              @unique @default(cuid())
  minBudget    Int?
  maxBudget    Int?
  currency     String              @default("RUB")
  drawAt       DateTime?
  seasonYear   Int
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // currentRoundId: the single authoritative pointer to the live/most-recent round.
  // null  = no completed draw yet (DRAFT / OPEN / LOCKED pre-first-draw).
  // set   = atomically after drawStatus → DONE in the draw endpoint.
  // never cleared when starting next round (old round stays visible as history).
  // updated to new round.id when next draw completes.
  currentRoundId String? @unique

  // onDelete: Restrict — prevents user account deletion while owning an active campaign.
  owner               User                  @relation("OwnedSantaCampaigns", fields: [ownerId], references: [id], onDelete: Restrict)
  currentRound        SantaRound?           @relation("CampaignCurrentRound", fields: [currentRoundId], references: [id], onDelete: SetNull)
  participants        SantaParticipant[]
  rounds              SantaRound[]          @relation("CampaignRounds")
  chatMessages        SantaChatMessage[]
  readCursors         SantaChatReadCursor[]
  chatMutes           SantaChatMute[]
  polls               SantaPoll[]
  notifications       SantaNotification[]
  auditLogs           SantaAdminAuditLog[]
  hintRequests        SantaHintRequest[]
  exclusionGroups     SantaExclusionGroup[]
  exitRequests        SantaExitRequest[]
  linkedGiftOccasions GiftOccasion[]        @relation("GiftOccasionsLinkedSanta")

  @@index([ownerId])
  @@index([inviteToken])
  @@index([seasonYear])
}

model SantaParticipant {
  id               String                 @id @default(cuid())
  campaignId       String
  userId           String
  status           SantaParticipantStatus @default(JOINED)
  role             SantaParticipantRole   @default(PARTICIPANT)
  linkedWishlistId String?
  joinedAt         DateTime               @default(now())
  leftAt           DateTime?

  campaign             SantaCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user                 User                    @relation("SantaParticipations", fields: [userId], references: [id], onDelete: Cascade)
  // onDelete: SetNull — DB-level emergency fallback only. Service layer blocks wishlist deletion if linked to active campaign.
  linkedWishlist       Wishlist?               @relation("SantaLinkedWishlists", fields: [linkedWishlistId], references: [id], onDelete: SetNull)
  giverAssignments     SantaAssignment[]       @relation("GiverAssignments")
  receiverAssignments  SantaAssignment[]       @relation("ReceiverAssignments")
  chatMessages         SantaChatMessage[]
  readCursors          SantaChatReadCursor[]
  chatMutes            SantaChatMute[]
  pollVotes            SantaPollVote[]
  createdPolls         SantaPoll[]             @relation("PollCreator")
  giverHintRequests    SantaHintRequest[]      @relation("HintGiverRequests")
  receiverHintRequests SantaHintRequest[]      @relation("HintReceiverRequests")
  exitRequests         SantaExitRequest[]
  aliases              SantaParticipantAlias[]

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
  @@index([linkedWishlistId])
}

model SantaRound {
  id          String          @id @default(cuid())
  campaignId  String
  roundNumber Int             @default(1)
  drawStatus  SantaDrawStatus @default(PENDING)
  drawJobId   String?
  drawnAt     DateTime?
  createdAt   DateTime        @default(now())

  campaign     SantaCampaign           @relation("CampaignRounds", fields: [campaignId], references: [id], onDelete: Cascade)
  // currentOf: back-relation for SantaCampaign.currentRound (at most one campaign at a time)
  currentOf    SantaCampaign?          @relation("CampaignCurrentRound")
  assignments  SantaAssignment[]
  polls        SantaPoll[]
  hintRequests SantaHintRequest[]
  exitRequests SantaExitRequest[]
  aliases      SantaParticipantAlias[]

  @@unique([campaignId, roundNumber])
  @@index([campaignId])
}

model SantaAssignment {
  id                    String          @id @default(cuid())
  roundId               String
  giverParticipantId    String
  receiverParticipantId String
  giftStatus            SantaGiftStatus @default(PENDING)
  giftNote              String?
  // Set the first time the receiver views their reveal — for analytics and completeness tracking.
  // Never exposed to any party other than the receiver themselves.
  revealedAt            DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  round                 SantaRound             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  giver                 SantaParticipant       @relation("GiverAssignments", fields: [giverParticipantId], references: [id], onDelete: Cascade)
  receiver              SantaParticipant       @relation("ReceiverAssignments", fields: [receiverParticipantId], references: [id], onDelete: Cascade)
  giftProgress          SantaGiftProgress[]
  hintRequests          SantaHintRequest[]
  santaItemReservations SantaItemReservation[]

  // Both uniques enforced: one person gives once AND receives once per round.
  @@unique([roundId, giverParticipantId])
  @@unique([roundId, receiverParticipantId])
  @@index([roundId])
}

model SantaGiftProgress {
  id           String          @id @default(cuid())
  assignmentId String
  status       SantaGiftStatus
  note         String?
  createdAt    DateTime        @default(now())

  assignment SantaAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

model SantaExclusion {
  id         String   @id @default(cuid())
  campaignId String
  userId1    String
  userId2    String
  createdAt  DateTime @default(now())

  @@unique([campaignId, userId1, userId2])
  @@index([campaignId])
}

// Batch 5.1: Named exclusion group — "no pairs within this group"
// Groups expand to all-pairs (C(n,2)) in-memory at draw/validate time.
// Zero materialization risk: individual SantaExclusion rows are NOT created.
model SantaExclusionGroup {
  id         String   @id @default(cuid())
  campaignId String
  label      String // organizer-defined name, e.g. "Family", "Same team"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign SantaCampaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  members  SantaExclusionGroupMember[]

  @@index([campaignId])
}

model SantaExclusionGroupMember {
  id      String @id @default(cuid())
  groupId String
  userId  String

  group SantaExclusionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User                @relation("ExclusionGroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

// Santa Hint Request — Batch 2.5
// A giver (anonymously) requests the receiver to hint which wishlist items they'd like.
// Receiver selects 1–3 items from their linked wishlist; giver sees the selection (no receiver identity).
//
// STATE MACHINE:
//   PENDING   → FULFILLED  (receiver selects items within TTL)
//   PENDING   → EXPIRED    (TTL job: expiresAt < now && status=PENDING)
//   PENDING   → CANCELLED  (campaign cancelled; cancel endpoint bulk-updates)
//   All terminal states: FULFILLED, EXPIRED, CANCELLED
//
// CONSTRAINT: at most one PENDING hint per assignment (application-enforced, not DB unique).
// Sequential hints are allowed: after FULFILLED/EXPIRED, giver may create a new PENDING request.
// After CANCELLED: no new requests (campaign/draw context gone).
//
// DRAW RESET: if assignments are ever deleted and re-drawn, all PENDING hints for those
// assignment IDs cascade-delete via onDelete: Cascade on assignmentId FK.
//
// ANONYMITY:
//   - receiverParticipantId is stored in DB but NEVER returned in any API response to giver
//   - giverParticipantId is stored in DB but NEVER returned in any API response to receiver
//   - Receiver endpoints use campaignId only — server resolves assignment internally
model SantaHintRequest {
  id                    String @id @default(cuid())
  // Campaign and round context — for lifecycle management and campaign-centric receiver lookup
  campaignId            String
  roundId               String
  // Assignment context — owns the hint; cascade-deletes on draw reset
  assignmentId          String
  // Denormalized for efficient one-sided queries (never exposed via API to the other side)
  giverParticipantId    String
  receiverParticipantId String

  status             SantaHintStatus @default(PENDING)
  // Wishlist item IDs selected by receiver. Null until FULFILLED. Max 3 items.
  // Stored as JSON array of item IDs; items validated against receiver's wishlist at fulfill time.
  selectedItemIds    Json? // String[]
  requestedAt        DateTime        @default(now())
  fulfilledAt        DateTime?
  expiresAt          DateTime // requestedAt + 48h; set at creation
  cancelledAt        DateTime?
  // Tracks whether HINT_REQUEST notification was sent to receiver (prevents duplicate sends)
  notificationSentAt DateTime?

  campaign            SantaCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  round               SantaRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  assignment          SantaAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  giverParticipant    SantaParticipant @relation("HintGiverRequests", fields: [giverParticipantId], references: [id], onDelete: Cascade)
  receiverParticipant SantaParticipant @relation("HintReceiverRequests", fields: [receiverParticipantId], references: [id], onDelete: Cascade)

  @@index([assignmentId, status])
  @@index([receiverParticipantId, status])
  @@index([campaignId, receiverParticipantId, status])
  @@index([expiresAt, status])
}

// Campaign-level group chat. Messages ordered by (createdAt, id).
// body = plain text for USER messages. SYSTEM messages set systemEvent + payload; body = "".
model SantaChatMessage {
  id            String               @id @default(cuid())
  campaignId    String
  participantId String // null-ish for SYSTEM: participantId = owner's participant id, body = ""
  body          String
  messageType   SantaChatMessageType @default(USER)
  systemEvent   String? // e.g. 'participant_joined', 'draw_done', 'campaign_cancelled'
  payload       Json? // structured data for system messages, e.g. {"displayName":"Ivan"}
  createdAt     DateTime             @default(now())

  campaign    SantaCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant SantaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt, id])
}

// Read cursor for unread count. Unread = messages WHERE (createdAt, id) > cursor pair.
model SantaChatReadCursor {
  id                String    @id @default(cuid())
  campaignId        String
  participantId     String
  lastReadMessageId String?
  lastReadAt        DateTime?
  updatedAt         DateTime  @updatedAt

  campaign    SantaCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant SantaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, participantId])
}

// Per-participant mute for campaign chat. Suppresses CHAT_MESSAGE + POLL_CREATED notifications.
// Does NOT suppress service notifications (draw, reveal, hints, deadlines, cancelled).
model SantaChatMute {
  id            String   @id @default(cuid())
  campaignId    String
  participantId String
  mutedAt       DateTime @default(now())

  campaign    SantaCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant SantaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, participantId])
}

model SantaPoll {
  id                     String    @id @default(cuid())
  campaignId             String // Primary scoping field — required
  roundId                String? // Optional; kept for round-specific context
  question               String
  options                Json // String[] — immutable after create
  isAnonymous            Boolean   @default(false)
  createdByParticipantId String?
  deadlineAt             DateTime?
  closedAt               DateTime?
  createdAt              DateTime  @default(now())

  campaign  SantaCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  round     SantaRound?       @relation(fields: [roundId], references: [id], onDelete: SetNull)
  createdBy SantaParticipant? @relation("PollCreator", fields: [createdByParticipantId], references: [id], onDelete: SetNull)
  votes     SantaPollVote[]

  @@index([campaignId])
}

model SantaPollVote {
  id            String   @id @default(cuid())
  pollId        String
  participantId String
  optionIndex   Int
  createdAt     DateTime @default(now())

  poll        SantaPoll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  participant SantaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([pollId, participantId])
}

model SantaNotification {
  id         String                @id @default(cuid())
  campaignId String
  userId     String
  type       SantaNotificationType
  payload    Json?
  /// Explicit dedup key. When set, uniqueness is enforced per (userId, type, dedupeKey)
  /// via a DB partial unique index (WHERE dedupeKey IS NOT NULL). Null = no dedup.
  /// Conventions: draw:{roundId} | gift:{assignmentId} | reveal:{assignmentId}
  ///              cancel:{campaignId} | missed:{assignmentId} | warn:{assignmentId}
  dedupeKey  String?
  readAt     DateTime?
  createdAt  DateTime              @default(now())

  campaign SantaCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User          @relation("SantaNotifications", fields: [userId], references: [id], onDelete: Cascade)
  // Partial unique index on (userId, type, dedupeKey) WHERE dedupeKey IS NOT NULL
  // is managed via raw SQL migration — not representable in Prisma schema syntax.

  @@index([userId, readAt])
  @@index([campaignId])
}

model SantaAdminAuditLog {
  id         String   @id @default(cuid())
  campaignId String
  actorId    String
  action     String
  payload    Json?
  createdAt  DateTime @default(now())

  campaign SantaCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// Exit request: participant asks organizer to let them leave a LOCKED or ACTIVE campaign.
// After approval the participant is set to REMOVED and any non-terminal ACTIVE-round
// assignment from that participant is set to ORPHANED (terminal).
model SantaExitRequest {
  id            String                 @id @default(cuid())
  campaignId    String
  participantId String
  roundId       String? // round active at request time (context only)
  reason        String?
  status        SantaExitRequestStatus @default(PENDING)
  resolvedAt    DateTime?
  createdAt     DateTime               @default(now())

  campaign    SantaCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant SantaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  round       SantaRound?      @relation(fields: [roundId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([participantId])
}

// Lightweight analytics event log — used for god-mode dashboard metrics.
// Only specific server-side events are persisted here (feature gate hits, etc.).
// Not a full event sourcing system — only what the god-stats endpoint queries.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  userId    String?
  props     Json? // structured event properties for god-mode queries (variant_key, etc.)
  createdAt DateTime @default(now())
  // GIN(props jsonb_path_ops) is applied OUT OF BAND — see
  // docs/ops/analytics-index.md + ops/migrations/2026-05-19-analytics-props-gin-index.sql.
  // Do NOT add it as @@index here: Prisma wraps migrations in BEGIN/COMMIT
  // and CREATE INDEX CONCURRENTLY is rejected inside a transaction.

  @@index([event, createdAt])
  @@index([userId, event])
}

// A/B experiment infrastructure — one sticky bucket assignment per (user,
// experiment). Phase 0 of docs/research/06-experiment-backlog.md.
//
// The row is the source of truth for stickiness: once written, the variant
// never changes when EXP_<NAME>_ROLLOUT shifts later — only ENABLED=false
// (the kill switch) overrides it. It is also the dedup guard for the
// `experiment.assigned` analytics event: the (userId, experimentKey) unique
// index means the row — and the event — is created exactly once per user
// per experiment, even under concurrent requests.
//
// See apps/api/src/services/experiments.service.ts and
// docs/research/experiments/README.md.
model ExperimentAssignment {
  id            String   @id @default(cuid())
  userId        String
  experimentKey String
  variant       String // 'control' | 'treatment'
  holdout       Boolean  @default(false) // true → global holdout cohort
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experimentKey])
  @@index([experimentKey, variant])
}

// Daily product-loop rollup — one row per (userId, UTC calendar day).
// Source = AnalyticsEvent, which has a 90-day TTL. The aggregator runs
// hourly and re-computes yesterday + today in UTC, idempotently upserting
// by (userId, date). Survives the AnalyticsEvent TTL so D30/D60/D90
// cohorts, share rate D7, guest→owner D7, reservation rate, and paywall
// conversion stay queryable indefinitely. See:
//   - apps/api/src/services/daily-activity.service.ts (event→field mapping)
//   - apps/api/src/schedulers/daily-activity-rollup.ts (hourly cron)
//   - apps/api/src/scripts/backfill-daily-activity.ts (one-shot backfill)
//   - docs/research/core-loop-dashboard.md (SQL panels)
model UserDailyActivity {
  userId                String
  date                  DateTime @db.Date // UTC calendar day
  sessionStarted        Int      @default(0)
  createdRealWish       Int      @default(0)
  createdWishlist       Int      @default(0)
  sharedWishlist        Int      @default(0)
  guestOpened           Int      @default(0)
  reservedItem          Int      @default(0)
  convertedGuestToOwner Int      @default(0)
  paywallViewed         Int      @default(0)
  checkoutStarted       Int      @default(0)
  paymentCompleted      Int      @default(0)
  proActivated          Int      @default(0)
  usedUrlImport         Int      @default(0)
  usedHint              Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([date])
}

// Santa-flow item reservation: tracks which wishlist items the giver has "claimed"
// for their Secret Santa assignment. Only Santa-flow reservations drive the
// SELECTED_FROM_WISHLIST gift status and auto-sync back to PENDING on removal.
// Distinct from general ReservationEvent — receiver identity is never exposed.
model SantaItemReservation {
  id           String   @id @default(cuid())
  assignmentId String
  itemId       String
  createdAt    DateTime @default(now())

  assignment SantaAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, itemId])
  @@index([assignmentId])
  @@index([itemId])
}

// Round-scoped anonymous alias for a Secret Santa participant.
// Generated atomically at draw time; regenerated for every new round.
// adjectiveKey + animalKey are locale-independent — frontend re-renders in user's locale.
// alias is pre-rendered RU string stored for system messages and debug.
model SantaParticipantAlias {
  id            String   @id @default(cuid())
  roundId       String
  participantId String
  alias         String // pre-rendered RU: "Сонный жираф"
  emoji         String // "🦒"
  adjectiveKey  String // "sleepy"
  animalKey     String // "giraffe"
  createdAt     DateTime @default(now())

  round       SantaRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  participant SantaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([roundId, participantId])
  @@unique([roundId, alias])
  @@index([roundId])
  @@index([participantId])
}

// ─── Onboarding Engine ────────────────────────────────────────────────────────
// Tracks per-user, per-key, per-version onboarding state.
// Supports multiple onboarding flows without schema changes (onboardingKey + version as discriminators).
// demoItemId links to the specific Item created for this onboarding session —
// used for precise dismiss cleanup and becameRealAt targeting.
model UserOnboardingState {
  id               String           @id @default(cuid())
  userId           String
  onboardingKey    String // e.g. "hello_activation"
  version          Int // 1 — increment to re-show to all users
  status           OnboardingStatus @default(NOT_STARTED)
  variantKey       String? // assigned once on POST /start; never re-assigned
  entryPoint       String? // 'auto_after_first_wishlist' | 'organic_returning_underactivated' | 'forced_rollout_test' | 'manual_cta'
  demoItemId       String? // FK to the specific demo item for this onboarding state
  completionReason String? // 'demo_converted' | 'real_item_created' | 'demo_deleted_then_real_created'
  metaJson         Json?
  startedAt        DateTime?
  completedAt      DateTime?
  dismissedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, onboardingKey, version])
  @@index([userId])
}

// ═══════════════════════════════════════════
// Gift Notes — Поводы и идеи (v2)
// Personal gift idea notebook by occasions
// ═══════════════════════════════════════════

model GiftOccasion {
  id          String    @id @default(cuid())
  ownerUserId String
  title       String
  type        String    @default("OTHER") // BIRTHDAY, ANNIVERSARY, HOLIDAY, OTHER
  personName  String? // free text, no linked user requirement
  eventDate   DateTime? @db.Date
  recurrence  String    @default("NONE") // NONE, YEARLY, MONTHLY
  note        String?
  status      String    @default("ACTIVE") // ACTIVE, DONE, ARCHIVED

  // ─── v2.1 Events Calendar enrichment ───
  emoji          String?
  eventTime      String? // "HH:mm" 24h
  location       String?
  budgetMin      Int?
  budgetMax      Int?
  budgetCurrency String?

  // Source / provenance — drives import dedup + UI labels
  source     String  @default("USER") // USER | IMPORTED_FRIEND | IMPORTED_HOLIDAY
  holidayKey String? // when source=IMPORTED_HOLIDAY, FK-by-key into Holiday.key
  country    String? // ISO 3166-1 alpha-2 for imported holidays

  // Soft links — all SetNull-on-delete to keep occasions standalone
  linkedUserId     String?
  linkedWishlistId String?
  linkedSantaId    String?

  // Year-Recap tracking — filled when user marks event DONE
  actualGiftText     String?
  actualGiftAmount   Int?
  actualGiftCurrency String?
  thankYouNote       String?
  thankYouAt         DateTime?

  archivedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner          User                   @relation("GiftOccasionsOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  linkedUser     User?                  @relation("GiftOccasionsLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  linkedWishlist Wishlist?              @relation("GiftOccasionsLinkedWishlist", fields: [linkedWishlistId], references: [id], onDelete: SetNull)
  linkedSanta    SantaCampaign?         @relation("GiftOccasionsLinkedSanta", fields: [linkedSantaId], references: [id], onDelete: SetNull)
  ideas          GiftOccasionIdea[]
  reminders      GiftOccasionReminder[]
  inboxEntries   CalendarInboxEntry[]

  @@unique([ownerUserId, holidayKey])
  @@index([ownerUserId])
  @@index([ownerUserId, status])
  @@index([ownerUserId, eventDate])
  @@index([linkedUserId])
  @@index([linkedWishlistId])
  @@index([linkedSantaId])
}

model GiftOccasionIdea {
  id          String    @id @default(cuid())
  occasionId  String
  ownerUserId String
  text        String
  link        String?
  price       Int?
  currency    String?
  note        String?
  imageUrl    String?
  status      String    @default("ACTIVE") // ACTIVE, DONE, ARCHIVED
  archivedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  occasion GiftOccasion @relation(fields: [occasionId], references: [id], onDelete: Cascade)
  owner    User         @relation("GiftOccasionIdeasOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([occasionId])
  @@index([ownerUserId])
  @@index([occasionId, status])
}

// ═══════════════════════════════════════════
// Events Calendar v2.1 — Reminders / Holidays / Inbox
// ═══════════════════════════════════════════

model GiftOccasionReminder {
  id          String @id @default(cuid())
  occasionId  String
  ownerUserId String

  offsetDays Int
  timeOfDay  String  @default("10:00")
  enabled    Boolean @default(true)

  scheduledFor DateTime?
  sentAt       DateTime?
  delivered    Boolean   @default(false)

  episodeKey String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  occasion GiftOccasion @relation(fields: [occasionId], references: [id], onDelete: Cascade)
  owner    User         @relation("GiftOccasionRemindersOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([occasionId])
  @@index([ownerUserId])
  @@index([scheduledFor, sentAt, enabled])
}

// ═══════════════════════════════════════════
// Birthday Reminders — social notifications for own birthday
//
// SEPARATE from GiftOccasionReminder by design:
// - GiftOccasionReminder = personal calendar entries the user creates for friends
// - BirthdayReminderDelivery = system-driven notifications to a user's audience
//   when *their own* birthday approaches.
//
// Delivery dedup: unique (birthdayUserId, recipientUserId, occurrenceKey, reminderKind)
// occurrenceKey format: "YYYY-MM-DD" — the birthday's actual MSK date this year.
// Feb-29 birthdays in non-leap years use the Feb-28 occurrenceKey.
// reminderKind enum: friend_14d | friend_7d | friend_1d | friend_today |
//                    owner_30d | owner_14d | owner_7d | owner_today
// status enum: pending | sent | skipped | failed | deferred
//   - deferred used for daily-cap: deferredUntil set to next MSK 10:00, scheduler re-picks.
// ═══════════════════════════════════════════

model BirthdayReminderDelivery {
  id String @id @default(cuid())

  birthdayUserId  String
  recipientUserId String

  occurrenceKey String
  reminderKind  String

  status        String    @default("pending")
  skipReason    String?
  failureReason String?
  deferredUntil DateTime?

  telegramMessageId Int?

  // What the bot CTA points to. Computed at send-time, not creation-time, so
  // last-minute privacy changes are reflected.
  // targetType: wishlist | profile | own_wishlist | create_wishlist | wishlists_index
  targetType      String?
  targetId        String?
  deepLinkPayload String?

  // Used at send-time for analytics + audience attribution.
  // relationType (friend_*): subscription | wishlist_subscription | reservation | comment | mixed
  // For owner_* deliveries this is null.
  relationType String?

  sentAt    DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  birthdayUser User @relation("BirthdayDeliveriesAsBirthdayUser", fields: [birthdayUserId], references: [id], onDelete: Cascade)
  recipient    User @relation("BirthdayDeliveriesAsRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([birthdayUserId, recipientUserId, occurrenceKey, reminderKind])
  @@index([status, deferredUntil])
  @@index([recipientUserId, sentAt])
  @@index([birthdayUserId, occurrenceKey])
  @@index([sentAt])
  @@index([createdAt])
}

// Per-recipient mute of a specific birthday user. Created via inline-keyboard
// "🔕 Не напоминать об этом человеке" callback or via settings UI.
model BirthdayReminderMute {
  id                  String   @id @default(cuid())
  userId              String
  mutedBirthdayUserId String
  createdAt           DateTime @default(now())

  user      User @relation("BirthdayMutesByUser", fields: [userId], references: [id], onDelete: Cascade)
  mutedUser User @relation("BirthdayMutesAsMutedUser", fields: [mutedBirthdayUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mutedBirthdayUserId])
  @@index([userId])
}

model Holiday {
  id String @id @default(cuid())

  country String
  month   Int
  day     Int

  key String @unique

  emoji    String
  category String @default("NATIONAL")

  nameRu   String?
  nameEn   String?
  nameZhCn String?
  nameHi   String?
  nameEs   String?
  nameAr   String?

  ordinal Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([country, month, day])
}

model CalendarInboxEntry {
  id          String  @id @default(cuid())
  ownerUserId String
  occasionId  String?

  type  String
  emoji String
  title String
  body  String?

  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  owner    User          @relation("CalendarInboxOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  occasion GiftOccasion? @relation(fields: [occasionId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, readAt])
  @@index([ownerUserId, createdAt])
  @@index([occasionId])
}

// ─── Reservation Pro: private notes, purchased flag, reminders, history ──────
model ReservationMeta {
  id                    String    @id @default(cuid())
  itemId                String
  reserverUserId        String
  note                  String?   @db.VarChar(500)
  purchased             Boolean   @default(false)
  purchasedAt           DateTime?
  reminderAt            DateTime?
  reminderSent          Boolean   @default(false)
  reminderDates         Json? // string[] of all scheduled reminder ISO dates
  // History tracking — when the reservation ends, these fields get populated
  active                Boolean   @default(true)
  endedAt               DateTime?
  endReason             String? // 'unreserved' | 'completed' | 'archived'
  // Smart Reservations
  expiresAt             DateTime?
  extensionCount        Int       @default(0)
  isSmartRes            Boolean   @default(false)
  smartResTtlHours      Int? // snapshot of wishlist TTL at creation
  smartResMaxExtensions Int? // snapshot of max extensions at creation
  smartResAllowExtend   Boolean? // snapshot of allow extend at creation
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, reserverUserId])
  @@index([reserverUserId, active])
  @@index([reminderAt, reminderSent])
  @@index([isSmartRes, active, expiresAt])
}

// ─── Secret Reservation ──────────────────────────────────────────────────────
// Privacy-isolated from ReservationMeta / ReservationEvent.
// Creating / cancelling a SecretReservation MUST NOT touch Item.status,
// reserverUserId, reservationEpoch, or fire sendTgNotification.
// Derived statuses (ITEM_UPDATED / ITEM_DELETED / PUBLIC_RESERVED_BY_OTHER / ITEM_UNAVAILABLE /
// ITEM_FULFILLED) are computed at read time by comparing current Item state vs `snapshot`.
enum SecretReservationStatus {
  ACTIVE // normal happy state
  CANCELLED // user explicitly cancelled
  FULFILLED // user marked own reservation as purchased/gifted
  CONVERTED_TO_PUBLIC // user promoted secret reservation → public reservation
}

model SecretReservation {
  id                    String                  @id @default(cuid())
  itemId                String
  reserverUserId        String
  status                SecretReservationStatus @default(ACTIVE)
  // Snapshot of item fields at the time of secret reservation, used for diff detection:
  // { title, priceAmount, currency, url, imageUrl, description, priority, quantity }
  snapshot              Json
  updatesAcknowledgedAt DateTime?
  note                  String?                 @db.VarChar(500)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  cancelledAt           DateTime?
  fulfilledAt           DateTime?
  convertedAt           DateTime?

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reserver User @relation(fields: [reserverUserId], references: [id], onDelete: Cascade)

  @@unique([itemId, reserverUserId])
  @@index([reserverUserId, status])
  @@index([itemId])
}

model WishlistCategory {
  id         String   @id @default(cuid())
  wishlistId String
  name       String
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  wishlist   Wishlist                @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  items      Item[]
  placements WishlistItemPlacement[]

  @@index([wishlistId, sortOrder])
  @@index([wishlistId, isDefault])
}

// Per-wishlist placement for a (possibly shared) Item.
// An Item can live in 1..N wishlists via placement rows. Global fields
// (title, description, price, image, status, reservation, comments) stay
// on Item itself. Per-wishlist fields (position, category) live here.
//
// Dual-read window: Item.wishlistId / Item.position / Item.categoryId
// remain authoritative for legacy read paths; every Item has a placement
// in its wishlistId, backfilled 1-for-1 by migration.
model WishlistItemPlacement {
  id         String   @id @default(cuid())
  wishlistId String
  itemId     String
  position   Int      @default(0)
  categoryId String?
  addedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  wishlist Wishlist          @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  item     Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category WishlistCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([wishlistId, itemId])
  @@index([itemId])
  @@index([wishlistId, position])
  @@index([categoryId])
}

// ─── Foreign wishlist access history ─────────────────────────────────────────
// One row per (user, wishlist) the user has successfully opened that is NOT
// their own. Used as the "scope source" for global-search results coming from
// other people's wishlists: search runs against this set (intersected with
// the user's explicit relation graph), then every hit is re-checked for
// live access (archived / share-token / visibility / curated expiresAt /
// block-list). This row is access HISTORY, never a permission grant.
//
// Writes are routed through services/foreign-wishlist-access.ts so the same
// validation gate runs for every entry point (share link, curated, profile
// view, subscription, reservation context).
model ForeignWishlistAccess {
  id             String   @id @default(cuid())
  userId         String
  wishlistId     String
  // share_link | curated_selection | subscription | reservation | profile |
  // santa | direct_open | unknown — free-text on purpose, callers pass the
  // origin tag. New tags appear over time (e.g. group_gift) without a migration.
  source         String
  // Strict revocation pin for credential-based sources. Holds an opaque
  // reference to the credential used to gain access at record time:
  //   - source='share_link'        → SHA-256 of the shareToken in use
  //   - source='curated_selection' → CuratedSelection.id used to open
  //   - all other sources          → null (relation-grounded access is
  //                                   validated against the live relation
  //                                   table at check time, not via this ref).
  // At search/access-check time the live access check drops rows whose
  // sourceRef no longer matches the current credential — owner regenerated
  // the shareToken, curated selection expired or was deactivated, etc.
  sourceRef      String?
  firstOpenedAt  DateTime @default(now())
  lastOpenedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([userId, wishlistId])
  @@index([userId, lastOpenedAt])
  @@index([wishlistId])
}

// ─── Maintenance Recovery ─────────────────────────────────────────────────────

model MaintenanceIncident {
  id                      String    @id @default(cuid())
  startedAt               DateTime  @default(now())
  endedAt                 DateTime?
  status                  String    @default("active") // active | recovering | recovered
  recoveryConfirmedAt     DateTime?
  lastMaintenanceSignalAt DateTime  @default(now())
  exposureCount           Int       @default(0)
  notificationsSent       Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  exposures MaintenanceExposure[]

  @@index([status])
  @@index([startedAt])
}

model MaintenanceExposure {
  id             String    @id @default(cuid())
  incidentId     String
  userId         String
  surface        String // 'miniapp' | 'bot'
  locale         String    @default("ru")
  telegramChatId String?
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  notifiedAt     DateTime?
  returnedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  incident MaintenanceIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([incidentId, userId, surface])
  @@index([incidentId, notifiedAt])
  @@index([userId])
}

// ═══════════════════════════════════════════
// Group Gift — Совместный подарок
// Split gift collection among multiple participants.
// One group gift per item; organizer creates it, participants join.
// ═══════════════════════════════════════════

enum GroupGiftStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model GroupGift {
  id              String          @id @default(cuid())
  itemId          String          @unique
  organizerUserId String
  targetAmount    Int // whole units (e.g. 32990 = 32 990 ₽)
  currency        Currency        @default(RUB)
  deadline        DateTime?       @db.Date
  note            String?         @db.VarChar(500)
  pinnedInfo      String?         @db.VarChar(1000)
  status          GroupGiftStatus @default(OPEN)
  inviteToken     String          @unique @default(cuid())
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  item         Item                   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  organizer    User                   @relation("GroupGiftOrganizer", fields: [organizerUserId], references: [id], onDelete: Cascade)
  participants GroupGiftParticipant[]
  messages     GroupGiftMessage[]

  @@index([organizerUserId])
  @@index([inviteToken])
  @@index([status])
}

model GroupGiftParticipant {
  id          String   @id @default(cuid())
  groupGiftId String
  userId      String
  amount      Int // pledged amount in whole units
  displayName String
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groupGift GroupGift @relation(fields: [groupGiftId], references: [id], onDelete: Cascade)
  user      User      @relation("GroupGiftParticipations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupGiftId, userId])
  @@index([userId])
  @@index([groupGiftId])
}

model GroupGiftMessage {
  id           String   @id @default(cuid())
  groupGiftId  String
  senderUserId String
  text         String   @db.VarChar(2000)
  type         String   @default("USER") // USER | SYSTEM
  createdAt    DateTime @default(now())

  groupGift GroupGift @relation(fields: [groupGiftId], references: [id], onDelete: Cascade)
  sender    User      @relation("GroupGiftMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([groupGiftId, createdAt])
  @@index([senderUserId])
}

model CuratedSelection {
  id            String    @id @default(cuid())
  wishlistId    String
  ownerId       String
  title         String    @db.VarChar(100)
  shareToken    String    @unique
  viewCount     Int       @default(0)
  deactivatedAt DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  wishlist      Wishlist                       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  owner         User                           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items         CuratedSelectionItem[]
  subscriptions CuratedSelectionSubscription[]

  @@index([ownerId])
  @@index([wishlistId])
  @@index([shareToken])
  @@index([expiresAt])
}

model CuratedSelectionItem {
  id                 String   @id @default(cuid())
  curatedSelectionId String
  originalItemId     String?
  position           Int      @default(0)
  title              String
  priceText          String?
  currency           Currency @default(RUB)
  imageUrl           String?
  url                String?
  description        String?  @db.VarChar(500)

  curatedSelection CuratedSelection @relation(fields: [curatedSelectionId], references: [id], onDelete: Cascade)

  @@index([curatedSelectionId])
}

model CuratedSelectionSubscription {
  id                 String   @id @default(cuid())
  curatedSelectionId String
  subscriberId       String
  createdAt          DateTime @default(now())

  curatedSelection CuratedSelection @relation(fields: [curatedSelectionId], references: [id], onDelete: Cascade)
  subscriber       User             @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([curatedSelectionId, subscriberId])
  @@index([subscriberId])
  @@index([curatedSelectionId])
}

// ====================================================================
// REFERRAL PROGRAM — data model
// ====================================================================
// See /mockups/referral-program.html for the full spec + observability.
// Attribution is first-touch, locked. Inviter gets 30 PRO days when invitee
// completes a qualifying action (first wishlist + first item) within a window.

// One attribution record per (inviter, invitee) pair. Unique on invitedUserId
// to enforce "invitee can only be referred by one person, ever".
model ReferralAttribution {
  id            String @id @default(cuid())
  inviterUserId String
  invitedUserId String @unique
  referralCode  String
  // Where the link came from. Currently always 'telegram' (via bot /start payload).
  // Reserved for future: web-share, qr, native-share, etc.
  source        String @default("telegram")

  // Default = PENDING_ACTIVATION (invitee created + linked, awaiting qualifying
  // actions). The `ATTRIBUTED` enum value is reserved for future pre-user-
  // creation click events (e.g. web-share lands before /start is fired). All
  // current code paths enter via tryCreateAttribution which sets this state
  // explicitly — the default exists only as a safety net.
  status       ReferralAttributionStatus @default(PENDING_ACTIVATION)
  rejectReason ReferralRejectReason?

  // Lifecycle timestamps — each set once on transition, never updated.
  attributedAt     DateTime  @default(now())
  qualifiedAt      DateTime?
  rewardedAt       DateTime?
  rejectedAt       DateTime?
  // Deadline for qualifying action — config.qualificationWindowDays after attribution.
  // Cron sweeps for attributions with status=PENDING_ACTIVATION where now > windowDeadlineAt.
  windowDeadlineAt DateTime

  // Fraud — score is cumulative weights of triggered signals (0..100).
  // triggeredSignals is JSON array of { signal, weight, details }.
  // configVersion locks which config/weights were in effect for reproducibility.
  fraudScore       Int     @default(0)
  triggeredSignals Json?
  configVersion    String?
  configSnapshot   Json?

  // Device/network snapshot at attribution time — for fraud-ring debugging.
  // Hashed (sha256 + rotating salt) so we never store PII. Snapshots kept per-
  // attribution (not joined at read time) so clusters remain queryable even
  // if the salt rotates later.
  ipHash                String?
  deviceFingerprintHash String?
  timezone              String?
  locale                String?
  telegramClient        String?
  platform              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inviter User             @relation("ReferralInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invited User             @relation("ReferralInvitee", fields: [invitedUserId], references: [id], onDelete: Cascade)
  rewards ReferralReward[]

  @@index([inviterUserId, status])
  @@index([referralCode])
  @@index([status, windowDeadlineAt])
  @@index([status, fraudScore])
  @@index([ipHash])
  @@index([deviceFingerprintHash])
  @@index([createdAt])
}

// One record per granted reward. Decoupled from ReferralAttribution so we can
// have revoke history + support partial/admin manual grants later.
// idempotencyKey enforces exactly-once grant per (attribution, reason).
model ReferralReward {
  id              String               @id @default(cuid())
  userId          String
  attributionId   String?
  rewardType      String               @default("pro_days")
  rewardValueDays Int
  status          ReferralRewardStatus @default(GRANTED)

  // Strategy applied when granting: 'stack' (added to existing expiry) or 'replace' (set to now + days).
  grantStrategy    String    @default("stack")
  previousExpiryAt DateTime?
  newExpiryAt      DateTime?

  idempotencyKey   String    @unique
  grantedAt        DateTime  @default(now())
  revokedAt        DateTime?
  revokedReason    String?
  // Admin who granted/revoked manually — null for system grants.
  grantedByAdminId String?
  revokedByAdminId String?

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attribution ReferralAttribution? @relation(fields: [attributionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([attributionId])
  @@index([grantedAt])
}

// Singleton config table — all values tweakable without deploy.
// Every config change increments configVersion for reproducibility of old events.
// Only ONE row expected (enforced by unique id='default' constant).
model ReferralProgramConfig {
  id      String  @id @default("default")
  enabled Boolean @default(false)

  // Reward mechanics
  rewardDaysInviter Int    @default(30)
  grantStrategy     String @default("stack") // stack | replace

  // Qualifying action requirements
  requireWishlist         Boolean @default(true)
  requireItem             Boolean @default(true)
  qualificationWindowDays Int     @default(14)

  // Rate limits / caps
  monthlyRewardCap Int @default(3)
  yearlyRewardCap  Int @default(12)

  // Fraud thresholds
  fraudAutoRejectThreshold Int     @default(80)
  fraudReviewThreshold     Int     @default(40)
  fraudReviewEnabled       Boolean @default(true)

  // Signal weights — tweakable; writable from admin. Each key matches fraud signal name.
  fraudSignalWeights Json @default("{\"ip_cluster\":30,\"device_fingerprint\":25,\"velocity\":20,\"inactive_invitee\":15,\"same_tz_cluster\":10,\"self_referral\":100,\"suspicious_onboarding\":25,\"account_age_delta\":20}")

  // UI toggles
  showInviteeNamesInUi Boolean @default(false)
  entryPointProfile    Boolean @default(true)
  entryPointPaywall    Boolean @default(true)
  entryPointHomeBanner Boolean @default(true)
  entryPointPostShare  Boolean @default(true)

  // Bot notification toggles
  notifyInviterArrival      Boolean @default(true)
  notifyInviterStepProgress Boolean @default(false)
  notifyInviterReward       Boolean @default(true)
  notifyInviteeWelcome      Boolean @default(false)

  // Rollout gating — % of users exposed in soft launch. 0..100.
  rolloutPercent Int @default(10)

  // Opaque version ID incremented server-side on every update — referenced
  // from AnalyticsEvent.configVersion so old events can be reproduced exactly.
  configVersion String @default("v1")

  updatedAt        DateTime @updatedAt
  updatedByAdminId String?
}

// Idempotency-Key store. One row per (key + actor + method + route-pattern).
// On replay we compare requestHash; matches return stored responseStatus/responseBody,
// mismatches return 409. Rows are TTL'd (default 24 h, billing endpoints 7 d) and
// purged by an in-process cleanup job once expiresAt passes.
//
// `path` holds the route pattern (e.g. /tg/wishlists/:id/items), not the literal URL.
// Literal IDs and query params are folded into requestHash so two reservations of
// different items can't collide on the same key.
//
// `responseBody` is capped at ~64 KB; oversized responses are stored with body=null
// and `responseTruncated=true`. Multipart endpoints opt out of replay and are stored
// the same way (lock-only).
model IdempotencyKey {
  id                String            @id @default(cuid())
  key               String
  userId            String?
  // Logical actor identity (tgActorHash UUID). Null for unauth callers — kept
  // separate from `actorKey` so audits can tell auth from unauth at a glance.
  actorHash         String?
  // Dedup key — never null. Equals `actorHash` for auth'd users, `ip:<hash>`
  // for unauth. Required because Prisma composite-unique whereUnique inputs
  // can't carry nulls (Postgres treats NULLs as distinct, defeating dedup).
  actorKey          String
  method            String
  path              String
  requestHash       String
  responseStatus    Int?
  responseBody      Json?
  responseTruncated Boolean           @default(false)
  status            IdempotencyStatus
  lockedUntil       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  expiresAt         DateTime

  @@unique([key, actorKey, method, path])
  @@index([expiresAt])
  @@index([actorHash, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Research surveys — localized PMF-style questionnaires
//
// Survey definitions live in code (`SURVEY_PMF_V1` const). The DB stores
// metadata (status, version), invites (one per user per survey),
// completions (one response per invite), and individual answers
// (one row per selected optionId — multi-choice safe).
//
// PII discipline: no telegramId, username, firstName, lastName, or raw
// item titles. answerText permitted only for `optionId IN ('__text__','other')`.
// ─────────────────────────────────────────────────────────────

enum ResearchSurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ResearchSurveyInviteStatus {
  PENDING
  SENT
  OPENED
  STARTED
  COMPLETED
  DISMISSED
  FAILED
}

model ResearchSurvey {
  id        String               @id @default(cuid())
  slug      String
  version   Int                  @default(1)
  status    ResearchSurveyStatus @default(DRAFT)
  openedAt  DateTime?
  closedAt  DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  invites   ResearchSurveyInvite[]
  responses ResearchSurveyResponse[]

  @@unique([slug, version])
  @@index([status])
}

// One row per (survey, user). Unique constraint blocks duplicate invites.
// segmentSubtype is set only for S8 (behavioral dropout stage) and stays
// null for S1/S2/S3/S5/S7. Both segmentId and segmentSubtype are captured
// at recipient-selection time and never recomputed afterwards.
model ResearchSurveyInvite {
  id             String                     @id @default(cuid())
  surveyId       String
  survey         ResearchSurvey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId         String
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  segmentId      String
  segmentSubtype String?
  locale         String
  status         ResearchSurveyInviteStatus @default(PENDING)
  sentAt         DateTime?
  openedAt       DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  dismissedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  response ResearchSurveyResponse?

  @@unique([surveyId, userId])
  @@index([surveyId, status])
  @@index([status, sentAt])
  @@index([surveyId, segmentId, segmentSubtype])
}

// One row per completed (or in-progress) flow. rewardKind/rewardGrantedAt
// are written only at /complete, never at /start or /answer.
//   'pro_30d'                — +30 days extension or new monthly Subscription
//   'pro_30d_lifetime_noop'  — lifetime user; no Subscription mutation, but
//                              response is marked as rewarded for idempotency
model ResearchSurveyResponse {
  id              String               @id @default(cuid())
  surveyId        String
  survey          ResearchSurvey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  inviteId        String               @unique
  invite          ResearchSurveyInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  segmentId       String
  segmentSubtype  String?
  locale          String
  startedAt       DateTime             @default(now())
  completedAt     DateTime?
  rewardKind      String?
  rewardGrantedAt DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  answers ResearchSurveyAnswer[]

  @@unique([surveyId, userId])
  @@index([surveyId, completedAt])
  @@index([segmentId, segmentSubtype, completedAt])
}

// One row per selected optionId. multi-choice questions (Q3/Q6/Q7) create
// up to 2 rows per (response, question). Single-choice creates exactly 1.
// NPS (Q9) uses optionId='score_0'..'score_10'. Open text (Q10) uses
// optionId='__text__' with answerText populated. Any other question's
// 'other' option may also carry answerText.
//
// On edit, the server deletes all rows for (responseId, questionId) and
// recreates new ones inside one transaction — see services/research-survey.
model ResearchSurveyAnswer {
  id         String                 @id @default(cuid())
  responseId String
  response   ResearchSurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  optionId   String
  answerText String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([responseId, questionId, optionId])
  @@index([questionId, optionId])
  @@index([responseId, questionId])
}
