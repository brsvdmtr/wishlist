{
  "name": "wishlist",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @wishlist/web --filter @wishlist/api --filter @wishlist/bot dev",
    "dev:api": "pnpm --filter @wishlist/api dev",
    "dev:web": "pnpm --filter @wishlist/web dev",
    "build": "pnpm -r --sort build",
    "build:api": "pnpm --filter @wishlist/api build",
    "build:web": "pnpm --filter @wishlist/web build",
    "lint": "eslint .",
    "format": "prettier -w .",
    "seed": "pnpm --filter @wishlist/api seed",
    "db:generate": "pnpm -C packages/db db:generate",
    "db:migrate": "pnpm -C packages/db db:migrate:dev",
    "db:deploy": "pnpm -C packages/db db:migrate:deploy",
    "db:studio": "pnpm -C packages/db db:studio",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "test:coverage": "pnpm -r --workspace-concurrency=1 run test:coverage",
    "test:ops": "node --test ops/watchdog/state.test.mjs ops/deploy-workflow.test.mjs",
    "ui:audit": "node scripts/ui-audit.mjs",
    "ui:audit:json": "node scripts/ui-audit.mjs --json"
  },
  "devDependencies": {
    "@types/node": "20.14.11",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "typescript": "5.5.4",
    "vitest": "^2.1.9"
  }
}
