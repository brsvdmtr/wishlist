# Used by Prisma and the app (server-side)
DATABASE_URL="postgresql://wishlist:wishlist@localhost:5432/wishlist?schema=public"

# Telegram Bot token (keep secret, never commit real value)
TELEGRAM_BOT_TOKEN=""

# Used by docker-compose postgres
POSTGRES_USER="wishlist"
POSTGRES_PASSWORD="wishlist"
POSTGRES_DB="wishlist"
POSTGRES_PORT=5432
